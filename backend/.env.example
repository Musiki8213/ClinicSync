PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/clinicsync
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
# Optional: comma-separated list. Local dev also allows any localhost / 127.0.0.1 port in app.js.
# Set to true only if you want the API to auto-create admin@clinicsync.com in production (not recommended).
# BOOTSTRAP_DEMO_ADMIN=false
