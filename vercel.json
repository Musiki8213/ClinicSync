{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend/src/server.js",
      "routePrefix": "/_/backend",
      "framework": "express"
    }
  },
  "rewrites": [{ "source": "/((?!api)(?!_/backend).*)", "destination": "/index.html" }]
}
