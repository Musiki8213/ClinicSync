{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend",
      "framework": "express"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/_/backend/api/:path*" },
    { "handle": "filesystem" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
